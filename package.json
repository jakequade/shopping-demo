{
  "name": "pc-interview",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:api": "cd packages/api && bun run dev",
    "dev:web": "cd packages/web && bun run dev",
    "typecheck": "bun run typecheck:shared && bun run typecheck:api && bun run typecheck:web",
    "typecheck:shared": "cd packages/shared && bun run typecheck",
    "typecheck:api": "cd packages/api && bun run typecheck",
    "typecheck:web": "cd packages/web && bun run typecheck",
    "test:shared": "cd packages/shared && bun run test",
    "test:api": "cd packages/api && bun run test",
    "test:e2e": "cd packages/web && bun run test:e2e",
    "db:generate": "cd packages/api && bun run db:generate",
    "db:migrate": "cd packages/api && bun run db:migrate",
    "db:seed": "cd packages/api && bun run db:seed"
  },
  "devDependencies": {
    "pc-interview": ".",
    "typescript": "^6.0.3"
  }
}